# ════════════════════════════════════════════════════════════════
# FLiK — Rumah Sinema Indonesia
# Environment Configuration Template
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values
# cp .env.example .env && php artisan key:generate

APP_NAME=FLiK
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── DATABASE ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=velflix
DB_USERNAME=root
DB_PASSWORD=

# ── CACHE & SESSION ──────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120
# REQUIRED in production: forces the Secure flag on the session cookie
# so it never travels over plain HTTP. Leave unset (null) in local dev.
SESSION_SECURE_COOKIE=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── MAIL ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@flik.id"
MAIL_FROM_NAME="${APP_NAME}"

# ── STORAGE (Video Files) ────────────────────────────────────
# Default: "public" (Laravel local storage)
# Options: "public", "s3", "azure", "alibaba"
# Jika tidak diset atau "public", video disimpan di storage/app/public/videos
FILESYSTEM_DISK=public

# Public media disk — ALL user-uploaded images (posters, backdrops, cast
# photos, avatars, cover banners, mirrored TMDB art) read/written via
# App\Support\MediaDisk. Local dev: "public". Production on GCS: set to "s3"
# (the s3 block below targets the GCS interoperability endpoint).
MEDIA_DISK=public

# Amazon S3 (also works for DigitalOcean Spaces, MinIO, and Google Cloud
# Storage via its S3-compatible "interoperability" XML endpoint).
# For GCS: AWS_ACCESS_KEY_ID/SECRET = HMAC key pair, AWS_DEFAULT_REGION=auto,
# AWS_ENDPOINT=https://storage.googleapis.com, AWS_USE_PATH_STYLE_ENDPOINT=true,
# AWS_URL=https://storage.googleapis.com/<bucket> (needed so ->url() resolves),
# and the bucket must allow public reads (bucket-level access).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Azure Blob Storage (install: composer require microsoft/azure-storage-blob)
AZURE_STORAGE_NAME=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=videos
AZURE_STORAGE_URL=

# Alibaba Cloud OSS (install: composer require alphasnow/aliyun-oss-laravel)
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_ENDPOINT=

# ── PAYMENT GATEWAY (Midtrans) ───────────────────────────────
# Jika TIDAK diset → tombol payment disabled otomatis ("Coming Soon")
# Daftar di: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# ── TMDB API ─────────────────────────────────────────────────
TMDB_TOKEN=

# ── GOOGLE OAUTH ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT="${APP_URL}/login/google/callback"

# ── NEWSLETTER (Mailchimp) ───────────────────────────────────
MAILCHIMP_KEY=
MAILCHIMP_LIST_SUBSCRIBERS=

# ── PUSHER (Real-time) ───────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ── CLOUDFLARE TURNSTILE (CAPTCHA) ───────────────────────────
# Free, privacy-friendly drop-in CAPTCHA. Both keys must be set
# for the widget to engage; absent → graceful no-op (no widget
# rendered, validation rule passes). Login / register / forgot-
# password forms are gated when enabled. Comments require it
# only for new accounts (<24h) that have already posted >=3
# comments in the last hour. Get keys at:
#   https://dash.cloudflare.com → Turnstile → Add site
# Setup docs: docs/security/captcha.md
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── WAF-lite (RequestFirewall) ───────────────────────────────
# Signature-based request inspector. Blocks path traversal, SQLi,
# XSS, RCE, LFI/RFI, webshells before they reach a controller.
# Routes 'comment.*', 'admin.*', 'chat.*' skip body inspection
# (those legitimately receive code/markup — handled downstream).
# Set WAF_MODE=log_only in dev/staging while tuning rules.
# Set WAF_BYPASS_TOKEN to a long random string to allow DAST scans
# (header X-Bypass-Waf must match). Setup docs: docs/security/waf-lite.md
WAF_ENABLED=true
WAF_MODE=block
WAF_BYPASS_TOKEN=
WAF_IP_BAN_THRESHOLD=5
WAF_IP_BAN_MINUTES=60

# ── WEB PUSH NOTIFICATIONS (VAPID) ───────────────────────────
# Both keys must be set to enable push notifications. If unset:
#   - <x-push-opt-in /> banner hides
#   - /api/push/subscribe + /api/push/unsubscribe return 503
#   - Admin /admin/push routes refuse to send (with helpful message)
# Generate a keypair (one-time setup) with:
#   php artisan flik:push:generate-vapid-keys
# OR via Node (if installed):
#   npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a real `mailto:` or `https://` URL — push services
# (FCM / Mozilla / Apple) contact it about abuse. Default below is a safe
# placeholder; replace it before going live.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@flik.example.com"

# ── CORS (api/* + sanctum/csrf-cookie) ───────────────────────
# Comma-separated list of allowed origins. Defaults to APP_URL only
# (same-origin) when unset. NEVER use "*" — credentials mode is enabled
# and browsers reject the wildcard + credentials combination.
# Example: CORS_ALLOWED_ORIGINS="https://flik.id,https://admin.flik.id"
CORS_ALLOWED_ORIGINS=
