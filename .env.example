# ════════════════════════════════════════════════════════════════
# FLiK — Rumah Sinema Indonesia
# Environment Configuration Template
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values
# cp .env.example .env && php artisan key:generate

APP_NAME=FLiK
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── DATABASE ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=velflix
DB_USERNAME=root
DB_PASSWORD=

# ── CACHE & SESSION ──────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── MAIL ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@flik.id"
MAIL_FROM_NAME="${APP_NAME}"

# ── STORAGE (Video Files) ────────────────────────────────────
# Default: "public" (Laravel local storage)
# Options: "public", "s3", "azure", "alibaba"
# Jika tidak diset atau "public", video disimpan di storage/app/public/videos
FILESYSTEM_DISK=public

# Amazon S3 (also works for DigitalOcean Spaces, MinIO)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Azure Blob Storage (install: composer require microsoft/azure-storage-blob)
AZURE_STORAGE_NAME=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=videos
AZURE_STORAGE_URL=

# Alibaba Cloud OSS (install: composer require alphasnow/aliyun-oss-laravel)
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_ENDPOINT=

# ── PAYMENT GATEWAY (Midtrans) ───────────────────────────────
# Jika TIDAK diset → tombol payment disabled otomatis ("Coming Soon")
# Daftar di: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# ── TMDB API ─────────────────────────────────────────────────
TMDB_TOKEN=

# ── GOOGLE OAUTH ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT="${APP_URL}/login/google/callback"

# ── NEWSLETTER (Mailchimp) ───────────────────────────────────
MAILCHIMP_KEY=
MAILCHIMP_LIST_SUBSCRIBERS=

# ── PUSHER (Real-time) ───────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
