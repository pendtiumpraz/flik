{
    "name": "flik/flik",
    "type": "project",
    "description": "FLiK \u2014 Rumah Sinema Indonesia. Platform streaming film premium.",
    "keywords": [
        "streaming",
        "ott",
        "laravel",
        "flik"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^7.0",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/framework": "^12.0",
        "laravel/socialite": "^5.12",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "league/flysystem-google-cloud-storage": "^3.0",
        "livewire/livewire": "^3.5",
        "mailchimp/marketing": "^3.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.37",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.5",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/features.php",
            "app/Helpers/settings.php",
            "app/Helpers/infrastructure.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "audit:deps": [
            "@composer audit --format=plain",
            "npm audit --audit-level=high"
        ],
        "audit:mass-assignment": "grep -rE '\\$request->all\\(\\)|::create\\(\\$request->all\\(\\)\\)' app/ || echo 'clean'"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {},
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
